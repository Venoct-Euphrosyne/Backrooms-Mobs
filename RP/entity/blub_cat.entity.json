			"scripts": {
				"pre_animation": [
					"variable.random = math.random_integer(0, 1);",
					"variable.attack = math.sin(variable.attack_time * 45.0);",
					"variable.is_flat = query.skin_id == 0;",
					"variable.is_long = query.skin_id == 1;",
					"variable.is_round = query.skin_id == 2;",
					"variable.is_persian = query.variant == 6;"
				],
				"animate": [
					{
						"flat_general_default": "!query.is_sheared&&query.mark_variant!=20&&query.skin_id==0"
					},
					{
						"flat_general_happy": "query.is_sheared&&query.mark_variant!=20&&query.skin_id==0"
					},
					{
						"flat_general_angry": "query.mark_variant==20&&!query.is_sheared&&query.skin_id==0"
					},
					{
						"flat_persian": "variable.is_persian&&query.skin_id==0"
					},
