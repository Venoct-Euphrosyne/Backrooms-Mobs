{
	"format_version": "1.20.0",
	"animation_controllers": {
		"controller.animation.bacteria.general": {
			"initial_state": "idling",
			"states": {
				"idling": {
					"variables": {
						"is_walking": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 0,
								"0.1": 1
							}
						},
						"is_idling": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 1,
								"0.1": 0
							}
						}
					},
					"animations": [
						"look_at_target",
						{
							"idle_0": "variable.is_idling"
						},
						{
							"idle_1": "variable.is_idling"
						},
						{
							"walk": "variable.is_walking"
						}
					],
					"transitions": [
						{
							"attacking": "variable.attack&&variable.random==0"
						}
					],
					"blend_transition": 0.5
				},
				"attacking": {
					"animations": [
						"attack"
					],
					"transitions": [
						{
							"idling": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.15
				},
				"jumpscaring": {
					"animations": [
						"jumpscare"
					]
				}
			}
		}
	}
}