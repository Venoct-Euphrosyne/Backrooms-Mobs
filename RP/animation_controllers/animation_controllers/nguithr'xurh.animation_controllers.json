{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.nguithrxurh.move": {
			"initial_state": "idle",
			"states": {
				"idle": {
					"animations": [
						"idle"
					],
					"transitions": [
						{
							"walk": "query.ground_speed"
						},
						{
							"climb": "query.is_wall_climbing"
						}
					],
					"blend_transition": 0.4
				},
				"walk": {
					"animations": [
						"walk"
					],
					"transitions": [
						{
							"idle": "!query.ground_speed"
						},
						{
							"climb": "query.is_wall_climbing"
						}
					],
					"blend_transition": 0.4
				},
				"climb": {
					"animations": [
						"climb"
					],
					"transitions": [
						{
							"idle": "!query.ground_speed&&!query.is_wall_climbing"
						},
						{
							"walk": "query.ground_speed&&!query.is_wall_climbing"
						}
					]
				}
		}
	}
	}
}