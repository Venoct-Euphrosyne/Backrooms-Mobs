{
	"format_version": "1.20.0",
	"animation_controllers": {
		"controller.animation.flat_blub_cat.general_default": {
			"initial_state": "idling",
			"states": {
				"idling": {
					"variables": {
						"is_walking": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 0,
								"0.1": 1
							}
						},
						"is_idling": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 1,
								"0.1": 0
							}
						}
					},
					"animations": [
						"flat_blink",
						"flat_ear",
						{
							"flat_idle": "variable.is_idling"
						},
						{
							"flat_tail": "variable.is_walking"
						},
						{
							"flat_walk": "variable.is_walking"
						}
					],
					"transitions": [
						{
							"sitting": "query.is_sitting"
						},
						{
							"sleeping": "query.is_baby"
						}
					],
					"blend_transition": 0.15
				},
				"sitting": {
					"animations": [
						"flat_idle",
						"flat_sleep_0"
					],
					"transitions": [
						{
							"idling": "!query.is_sitting"
						}
					],
					"blend_transition": 0.15
				},
				"sleeping": {
					"animations": [
						"flat_sleep_0",
						"flat_sleep_1",
						"flat_tail"
					],
					"transitions": [
						{
							"idling": "!query.is_baby"
						}
					],
					"blend_transition": 0.15
				}
			}
		},
