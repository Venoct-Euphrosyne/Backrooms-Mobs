{
	"format_version": "1.20.0",
	"animation_controllers": {
		"controller.animation.duller.general": {
			"initial_state": "idling",
			"states": {
				"idling": {
					"variables": {
						"is_walking": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 0,
								"0.1": 1
							}
						},
						"is_idling": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 1,
								"0.1": 0
							}
						}
					},
					"animations": [
						"look_at_target",
						{
							"idle": "variable.is_idling"
						},
						{
							"walk": "variable.is_walking"
						}
					],
					"transitions": [
						{
							"sprinting": "query.is_sheared"
						},
						{
							"attacking": "variable.attack&&variable.random==0"
						}
					],
					"blend_transition": 0.15
				},
				"sprinting": {
					"animations": [
						"sprint"
					],
					"transitions": [
						{
							"idling": "!query.is_sheared"
						},
						{
							"attacking": "variable.attack&&variable.random==0"
						}
					],
					"blend_transition": 0.15
				},
				"attacking": {
					"animations": [
						"attack"
					],
					"transitions": [
						{
							"idling": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.15
				}
			}
		}
	}
}