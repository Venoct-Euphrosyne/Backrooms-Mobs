{
	"format_version": "1.20.0",
	"animation_controllers": {
		"controller.animation.bone_thief.general": {
			"initial_state": "idling",
			"states": {
				"idling": {
					"variables": {
						"is_idling": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 1,
								"0.1": 0
							}
						},
						"is_crawling": {
							"input": "query.modified_move_speed",
							"remap_curve": {
								"0.0": 0,
								"0.1": 1
							}
						}
					},
					"animations": [
						{
							"idle": "variable.is_idling"
						},
						{
							"crawl": "variable.is_crawling"
						}
					],
					"transitions": [
						{
							"chomping": "variable.attack&&variable.random==0"
						}
					]
				},
				"chomping": {
					"animations": [
						"chomp"
					],
					"transitions": [
						{
							"idling": "query.all_animations_finished"
						}
					]
				}
			}
		}
	}
}