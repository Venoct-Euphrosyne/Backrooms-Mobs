{
	"format_version": "1.21.0",
	"minecraft:entity": {
		"description": {
			"identifier": "ve:strider",
			"is_spawnable": true,
			"is_summonable": true
		},
		"component_groups": {
			"ve:neutral_state": {
				"minecraft:follow_range": {
					"value": 32
				},
				"minecraft:behavior.nearest_attackable_target": {
					"priority": 2,
					"must_see": true,
					"within_radius": 32,
					"must_see_forget_duration": 15,
					"entity_types": [
						{
							"filters": [
								{
									"test": "is_family",
									"value": "player",
									"subject": "other"
								}
							],
							"max_dist": 32
						}
					]
				}
			},
			"ve:alerted_state": {
				"minecraft:follow_range": {
					"value": 320
				},
				"minecraft:behavior.nearest_attackable_target": {
					"priority": 2,
					"must_see": true,
					"within_radius": 320,
					"must_see_forget_duration": 15,
					"entity_types": [
						{
							"filters": [
								{
									"test": "is_family",
									"value": "player",
									"subject": "other"
								}
							],
							"max_dist": 320
						}
					]
				}
			}
		},
		"components": {
			"minecraft:is_hidden_when_invisible": {},
			"minecraft:experience_reward": {
				"on_death": "query.last_hit_by_player?5:0"
			},
			"minecraft:type_family": {
				"family": [
					"monster",
					"hostile",
					"backrooms_strider",
					"backroom_entity"
				]
			},
			"minecraft:breathable": {
				"total_supply": 15,
				"suffocate_time": 0
			},
			"minecraft:scale": {
				"value": 1.625
			},
			"minecraft:health": {
				"value": 20
			},
			"minecraft:attack": {
				"damage": 8
			},
			"minecraft:movement": {
				"value": 0.35
			},
			"minecraft:movement.basic": {},
			"minecraft:navigation.walk": {
				"is_amphibious": true,
				"avoid_water": true,
				"can_walk": true,
				"can_pass_doors": true,
				"can_break_doors": true
			},
			"minecraft:jump.static": {},
			"minecraft:collision_box": {
				"width": 2.75,
				"height": 3.75
			},
			"minecraft:despawn": {
				"despawn_from_distance": {
					"max_distance": 32
				}
			},
			"minecraft:behavior.melee_attack": {
				"priority": 0,
				"reach_multiplier": 0.5,
				"attack_once": false,
				"track_target": true
			},
			"minecraft:behavior.random_stroll": {
				"priority": 3
			},
			"minecraft:behavior.look_at_player": {
				"priority": 4,
				"look_distance": 16,
				"probability": 0.5
			},
			"minecraft:on_target_acquired": {
				"target": "self",
				"event": "minecraft:entity_spawned"
			},
			"minecraft:on_friendly_anger": {
				"filters": {
					"test": "is_family",
					"value": "backroom_entity",
					"subject": "other"
				},
				"target": "self",
				"event": "ve:alerted_state_event"
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "all",
						"deals_damage": true,
						"damage_multiplier": 0.0125
					}
				]
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": false
			},
			"minecraft:knockback_resistance": {
				"value": 1
			},
			"minecraft:conditional_bandwidth_optimization": {
				"default_values": {
					"max_optimized_distance": 80,
					"max_dropped_ticks": 10,
					"use_motion_prediction_hints": true
				}
			}
		},
		"events": {
			"minecraft:entity_spawned": {
				"add": {
					"component_groups": [
						"ve:neutral_state"
					]
				},
				"remove": {
					"component_groups": [
						"ve:alerted_state"
					]
				}
			},
			"ve:alerted_state_event": {
				"add": {
					"component_groups": [
						"ve:alerted_state"
					]
				},
				"remove": {
					"component_groups": [
						"ve:neutral_state"
					]
				}
			}
		}
