					"entity_types": [
						{
							"filters": [
								{
									"all_of": [
										{
											"test": "is_family",
											"subject": "other",
											"value": "player"
										}
									]
								}
							],
							"max_dist": 16
						}
					]
				},
				"minecraft:on_target_escape": {
					"target": "self",
					"event": "ve:patrol_state_event"
				},
				"minecraft:timer": {
					"looping": false,
					"time": 5,
					"time_down_event": {
						"filters": [
							{
								"any_of": [
									{
										"test": "has_target",
										"subject": "self",
										"operator": "==",
										"value": false
									}
								]
							}
						],
						"event": "ve:patrol_state_event",
						"target": "self"
					}
				}
