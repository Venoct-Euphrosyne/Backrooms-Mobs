			"identifier": "ve:bone_thief",
			"is_spawnable": true,
			"is_summonable": true,
			"scripts": {
				"animate": [
					"bone_thief_jumpscare_controller"
				]
			},
			"animations": {
				"bone_thief_jumpscare": "animation.bone_thief_jumpscare",
				"bone_thief_jumpscare_controller": "controller.animation.bone_thief_jumpscare_controller"
