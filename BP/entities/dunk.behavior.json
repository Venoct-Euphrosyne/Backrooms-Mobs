{
	"format_version": "1.21.50",
	"minecraft:entity": {
		"description": {
			"identifier": "ve:dunk",
			"is_spawnable": true,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"bm:dunk_wild": {
				"minecraft:tameable": {
					"tame_event": {
						"target": "self",
						"event": "bm:dunk_tamed_event"
					}
				},
				"minecraft:experience_reward": {
					"on_bred": "Math.Random(1,7)",
					"on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
				},
				"minecraft:health": {
					"value": 25,
					"max": 25
				},
				"minecraft:behavior.nearest_attackable_target": {
					"priority": 0,
					"reselect_targets": true,
					"within_radius": 16
				},
				"minecraft:behavior.avoid_mob_type": {
					"priority": 1,
					"entity_types": [
						{
							"filters": {
								"test": "is_family",
								"subject": "other",
								"value": "player"
							},
							"max_dist": 10,
							"walk_speed_multiplier": 0.8,
							"sprint_speed_multiplier": 1.25
						}
					]
				},
				"minecraft:interact": {
					"interactions": {
						"interact_text": "Pet The Dunk",
						"on_interact": {
							"filters": {
								"all_of": [
									{
										"test": "is_family",
										"subject": "other",
										"value": "player"
									}
								]
							},
							"target": "self"
						}
					}
				}
			},
			"bm:dunk_tamed": {
				"minecraft:is_tamed": {},
				"minecraft:health": {
					"value": 25,
					"max": 25
				},
				"minecraft:sittable": {},
				"minecraft:behavior.teleport_to_owner": {
					"priority": 0,
					"filters": {
						"all_of": [
							{
								"test": "owner_distance",
								"operator": ">",
								"value": 5
							},
							{
								"test": "is_panicking"
							}
						]
					}
				},
				"minecraft:behavior.stay_while_sitting": {
					"priority": 1
				},
				"minecraft:behavior.follow_owner": {
					"priority": 2,
					"speed_multiplier": 1,
					"start_distance": 4,
					"stop_distance": 2
				}
			},

			"bm:basic_dunk": {
				"minecraft:variant": {
					"value": 0
				}
			},
			"bm:snow_dunk": {
				"minecraft:variant": {
					"value": 1
				}
			},
			"bm:field_dunk": {
				"minecraft:variant": {
					"value": 2
				}
			},
			"bm:stone_dunk": {
				"minecraft:variant": {
					"value": 3
				}
			},
			"bm:playhouse_dunk": {
				"minecraft:variant": {
					"value": 4
				}
			},
			"bm:beach_dunk": {
				"minecraft:variant": {
					"value": 5
				}
			},
			"bm:arcade_dunk": {
				"minecraft:variant": {
					"value": 6
				}
			}
		},
		"components": {
			"minecraft:is_hidden_when_invisible": {},
			"minecraft:type_family": {
				"family": [
					"neutral",
					"backroom_entity",
					"dunk"
				]
			},
			"minecraft:collision_box": {
				"width": 0.75,
				"height": 0.75
			},
			"minecraft:breathable": {
				"total_supply": 15,
				"suffocate_time": 0
			},
			"minecraft:hurt_on_condition": {
				"damage_conditions": [
					{
						"filters": {
							"test": "in_lava",
							"subject": "self",
							"operator": "==",
							"value": true
						},
						"cause": "lava",
						"damage_per_tick": 4
					}
				]
			},
			"minecraft:nameable": {},
			"minecraft:scale": {
				"value": 1.25
			},
			"minecraft:attack_damage": {
				"value": 8
			},
			"minecraft:movement": {
				"value": 0.175
			},
			"minecraft:navigation.walk": {
				"can_float": true,
				"avoid_water": true,
				"avoid_damage_blocks": true
			},
			"minecraft:movement.basic": {},
			"minecraft:jump.static": {},
			"minecraft:can_climb": {},
			"minecraft:despawn": {
				"despawn_from_distance": {}
			},
			"minecraft:behavior.float": {
				"priority": 0
			},
			"minecraft:behavior.panic": {
				"priority": 1,
				"speed_multiplier": 1.25
			},
			"minecraft:behavior.random_stroll": {
				"priority": 2,
				"speed_multiplier": 0.8
			},
			"minecraft:behavior.look_at_player": {
				"priority": 3
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": true,
				"is_pushable_by_piston": true
			},
			"minecraft:conditional_bandwidth_optimization": {}
		},
		"events": {
			"minecraft:entity_spawned": {
				"sequence": [
					{
						"randomize": [
					{
						"add": {
							"component_groups": [
								"bm:dunk_wild",
								"bm:basic_dunk"
							]
						}
					},
					{
						"add": {
							"component_groups": [
								"bm:dunk_wild",
								"bm:snow_dunk"
							]
						}
					},
					{
						"add": {
							"component_groups": [
								"bm:dunk_wild",
								"bm:field_dunk"
							]
						}
					},
					{
						"add": {
							"component_groups": [
								"bm:dunk_wild",
								"bm:stone_dunk"
							]
						}
					},
					{
						"add": {
							"component_groups": [
								"bm:dunk_wild",
								"bm:playhouse_dunk"
							]
						}
					},
					{
						"add": {
							"component_groups": [
								"bm:dunk_wild",
								"bm:beach_dunk"
							]
						}
					},
					{
						"add": {
							"component_groups": [
								"bm:dunk_wild",
								"bm:arcade_dunk"
							]
						}
					}
				]
				}
				]
			},
			"bm:dunk_tamed_event": {
				"sequence": [
					{
						"add": {
							"component_groups": [
								"bm:dunk_tamed"
							]
						}
					},
					{
						"remove": {
							"component_groups": [
								"bm:dunk_wild"
							]
						}
					}
				]
			}
		}
	}
}